{
  "name": "post-machine-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vercel dev",
    "build": "echo 'No build step required'",
    "start": "vercel dev",
    "deploy": "vercel --prod",
    "db:init": "wrangler d1 execute post-machine-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute post-machine-db --local --file=./schema.sql",
    "secrets": "node scripts/set-secrets.js",
    "logs":   "wrangler tail"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.3",
    "@upstash/redis": "^1.34.0",
    "zod": "^3.23.8",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "openai": "^4.52.7",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "vercel": "^37.10.0",
    "wrangler": "^3.60.0"
  }
}
